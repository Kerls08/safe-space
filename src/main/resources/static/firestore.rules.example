// Example Firestore rules for quick testing. Review and tighten before production.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to create posts (for anonymous posting) during development.
    match /posts/{postId} {
      allow create: if true;
      // Restrict reads to authenticated users (psychometrician) - adjust as needed.
      allow read: if request.auth != null && request.auth.uid != null;
    }

    // Deny access to everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
